APP_ENV=development
LOG_LEVEL=INFO
DEBUG=false
LLM_BASE_URL=https://api.openai.com/v1
LLM_AUTH_MODE=auto
LLM_API_KEY=your-api-key
LLM_SERVICE_TOKEN=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=60
# 控制 reasoning_mode 如何映射到 Provider 请求字段。
# 可选值：
# - none: 不映射，只作为运行元数据保留
# - reasoning_effort: 映射为 {"reasoning_effort": "<mode>"}
# - reasoning_object: 映射为 {"reasoning": {"effort": "<mode>"}}
LLM_REASONING_PARAM_STYLE=none
# 控制 direct write_file 前的内容完整性校验策略。
# - strict: 默认值；疑似截断、Python 语法错误等情况会拒绝落盘
# - permissive: 只要提取出 path/content 就允许落盘，更适合演示成功率优先的场景
WRITE_VALIDATION_MODE=strict
SESSION_ID=
WORKDIR=
# 可选：主业务 SQLite 单文件（会话、runs、trace、V2 等共用），默认 <仓库根>/.simple_code_agent.sqlite3
# SQLITE_DB_PATH=

