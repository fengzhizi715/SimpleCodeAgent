APP_ENV=development
LOG_LEVEL=INFO
DEBUG=false
LLM_BASE_URL=https://api.openai.com/v1
LLM_AUTH_MODE=auto
LLM_API_KEY=your-api-key
LLM_SERVICE_TOKEN=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=60
# 控制 reasoning_mode 如何映射到 Provider 请求字段。
# 可选值：
# - none: 不映射，只作为运行元数据保留
# - reasoning_effort: 映射为 {"reasoning_effort": "<mode>"}
# - reasoning_object: 映射为 {"reasoning": {"effort": "<mode>"}}
LLM_REASONING_PARAM_STYLE=none
SESSION_ID=
WORKDIR=
